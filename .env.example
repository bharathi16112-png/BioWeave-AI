# BioWeave-AI — optional free configuration
# Copy to .env and customize. All integrations work without keys.

# ── Free API keys (optional — improve rate limits) ─────────────────────────────
# NCBI: free at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your_ncbi_api_key_here

# OncoKB: free academic token at https://www.oncokb.org/apiAccess
# ONCOKB_API_TOKEN=

# ── Contact email for NCBI E-utilities etiquette ─────────────────────────────
BIOWEAVE_CONTACT_EMAIL=your_email@example.com

# ── Free open-source models (HuggingFace, no payment) ─────────────────────────
# Pathology ViT — default owkin/phikon (TCGA, no auth required)
# BIOWEAVE_PATHOLOGY_MODEL=owkin/phikon

# Genomic NER — default OpenMed (free, ~109M params)
# BIOWEAVE_NER_MODEL=OpenMed/OpenMed-NER-GenomicDetect-PubMed-109M
# BIOWEAVE_USE_ML_NER=true

# Disable all ML model loading (regex-only, fast CI)
# BIOWEAVE_DISABLE_ML=true

# Optional local LLM (requires GPU + model download)
BIOWEAVE_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

BIOWEAVE_LLM_QUANT=awq


# ── WSI tiling ────────────────────────────────────────────────────────────────
# BIOWEAVE_TILE_SIZE=224
# BIOWEAVE_MAX_TILES=16

# ── AutoDock Vina molecular docking ──────────────────────────────────────────
# Enable/disable live Vina docking (falls back to curated scores when false)
# BIOWEAVE_ENABLE_DOCKING=true

# Local cache for receptor PDBQT files (~5MB per target, downloaded once from RCSB)
# BIOWEAVE_DOCKING_CACHE=~/.cache/bioweave/docking

# Exhaustiveness: higher = more thorough docking but slower (12 recommended)
# BIOWEAVE_DOCKING_EXHAUSTIVENESS=12
